{
  "name": "@niceltd/sol-react",
  "version": "0.0.1",
  "description": "SOL Design System — React components (auto-converted from Angular SOL source)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "storybook dev -p 6009",
    "build": "tsc",
    "build-storybook": "storybook build",
    "build-storybook-prod": "npm run docs:json && storybook build",
    "docs:json": "storybook extract",
    "fetch-tokens": "cpy node_modules/@niceltd/sol-tokens/sol-tokens.css ./src/styles",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "npm run lint:code && npm run lint:styles",
    "lint:code": "eslint src --ext .js,.ts,.tsx,.jsx",
    "lint:styles": "stylelint \"src/**/*.{css,scss,sass}\"",
    "format": "prettier --write \"src/**/*.{js,ts,tsx,jsx,css,scss,mdx}\"",
    "format-check": "prettier --check \"src/**/*.{js,ts,tsx,jsx,css,scss,mdx}\"",
    "storybook": "storybook dev -p 6009",
    "e2e-suite_01": "npx playwright install chromium && npx playwright test --config=e2e/suite01/suite01.config.ts",
    "e2e-suite_02": "npx playwright install chromium && npx playwright test --config=e2e/suite02/suite02.config.ts",
    "e2e-suite_03": "npx playwright install chromium && npx playwright test --config=e2e/suite03/suite03.config.ts",
    "e2e-suite_04": "npx playwright install chromium && npx playwright test --config=e2e/suite04/suite04.config.ts",
    "e2e-suite_05": "npx playwright install chromium && npx playwright test --config=e2e/suite05/suite05.config.ts"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@floating-ui/react": "^0.26.0",
    "@niceltd/sol-tokens": "2.1.0",
    "ag-grid-community": "~31.0.0",
    "ag-grid-enterprise": "~31.0.0",
    "ag-grid-react": "~31.0.0",
    "moment": "^2.29.4",
    "moment-timezone": "^0.5.43",
    "nouislider": "^15.7.0",
    "react-day-picker": "^9.14.0",
    "react-toastify": "^10.0.0",
    "rxjs": "^7.8.0",
    "tippy.js": "^6.3.7",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.26.1",
    "@niceltd/cxone-client-platform-services": "^35.18.0",
    "@niceltd/cxone-playwright-test-utils": "^21.50.0",
    "@niceltd/eslint-config-cxone": "^3.12.0",
    "@playwright/test": "1.58.2",
    "@storybook/addon-a11y": "^8.0.6",
    "@storybook/addon-actions": "^8.0.6",
    "@storybook/addon-docs": "^8.0.6",
    "@storybook/addon-essentials": "^8.4.0",
    "@storybook/addon-interactions": "^8.0.6",
    "@storybook/addon-links": "^8.0.6",
    "@storybook/addon-mdx-gfm": "^8.0.6",
    "@storybook/blocks": "^8.4.0",
    "@storybook/manager-api": "^8.0.9",
    "@storybook/react": "^8.4.0",
    "@storybook/react-vite": "^8.4.0",
    "@storybook/test": "^8.4.0",
    "@storybook/theming": "^8.0.6",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/node": "^20.9.0",
    "@types/nouislider": "^15.0.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "copyfiles": "^2.4.1",
    "cpy-cli": "2.0.0",
    "eslint": "^8.35.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-jsdoc": "^46.0.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-prefer-arrow": "^1.2.1",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-sonarjs": "0.18.0",
    "eslint-plugin-unused-imports": "^3.0.0",
    "http-server": "^14.1.1",
    "jsdom": "^24.0.0",
    "marked": "^4.0.16",
    "node-html-parser": "^6.1.13",
    "prettier": "3.2.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rimraf": "^6.1.3",
    "source-map-support": "^0.5.21",
    "storybook": "^8.4.0",
    "stylelint": "^14.8.5",
    "stylelint-config-prettier": "^9.0.3",
    "stylelint-config-standard": "^25.0.0",
    "stylelint-config-standard-scss": "^4.0.0",
    "ts-log": "^2.2.4",
    "typescript": "5.2.2",
    "util": "^0.12.5",
    "vitest": "^1.0.0"
  },
  "cxonePeerDependencyOverrides": {
    "ag-grid-react": {
      "find": "~31.0.0",
      "replace": "^31.0.0"
    },
    "ag-grid-community": {
      "find": "~31.0.0",
      "replace": "^31.0.0"
    },
    "ag-grid-enterprise": {
      "find": "~31.0.0",
      "replace": "^31.0.0"
    }
  },
  "exports": {
    "./styles/global.css": {
      "style": "./src/styles/global.css"
    },
    "./styles/sol-tokens.css": {
      "style": "./src/styles/sol-tokens.css"
    }
  }
}
